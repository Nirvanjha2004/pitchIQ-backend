# PitchIQ backend — environment variables
# Copy to backend/.env and fill in your values

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Use the "Transaction" pooler URL from Supabase → Project Settings → Database
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Add ?ssl=require — asyncpg needs it explicitly for Supabase's pooler
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?ssl=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Use the rediss:// (TLS) URL from Upstash → your database → "Connect" tab
# Format: rediss://default:[password]@[endpoint].upstash.io:6379
REDIS_URL=rediss://default:[password]@[endpoint].upstash.io:6379

# ── LLM API keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Jina AI embeddings ────────────────────────────────────────────────────────
JINA_API_KEY=
EMBEDDING_MODEL=jina-embeddings-v3

# ── Web search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Auth (future) ─────────────────────────────────────────────────────────────
SECRET_KEY=changeme
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to your actual frontend domain(s)
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Deployment (used by docker-compose + certbot) ─────────────────────────────
# Your server's public domain name (must point to the EC2 instance IP)
DOMAIN=api.yourdomain.com
# Email for Let's Encrypt expiry notifications
CERTBOT_EMAIL=you@yourdomain.com
